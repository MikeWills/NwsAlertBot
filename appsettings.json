{
  // ============================================================================
  // LOCATION — shared geographic area + time zone, used by EVERY feed below
  // ============================================================================
  // Nws, Spc, SpcMcd, Hwo, Ero, and the map-image bounding-box fallback all resolve
  // their WFO/centroid/geometry from these same Zones and Counties. If you add
  // a new alert feed in the future, it should read from here too, not carry its
  // own copy of Zones/Counties/TimeZone.
  "Location": {
    "Zones":    [],
    "Counties": [],
    "TimeZone": "America/Chicago"
  },

  // ============================================================================
  // POLLING — master loop cadence, drives every feed's check cycle
  // ============================================================================
  // Each feed below still self-gates on its own CheckIntervalSeconds; this only
  // controls how often the orchestrator ticks and checks whether any feed is due.
  // Only NWS alerts and SPC MCDs ever trigger the accelerated (ActiveAlert*)
  // window — SPC Outlook and HWO never do.
  "Polling": {
    "PollIntervalSeconds": 300,
    "ActiveAlertPollIntervalSeconds": 60,
    "ActiveAlertWindowHours": 4,
    "ActiveAlertMinSeverity": "Severe,Extreme"
  },

  // ============================================================================
  // NWS ALERTS FEED — the MASTER filter (server-side, hard gate)
  // ============================================================================
  // Regular NWS warnings/watches/advisories + Special Weather Statements (SPS).
  // The Filter* fields below are sent to api.weather.gov as query parameters —
  // they restrict what NWS returns in the first place. Nothing downstream
  // (per-platform MinSeverity, EventTypes) can "un-filter" an alert excluded
  // here; if it's not in this list, the bot never sees it.
  // This filter does NOT apply to SPC Outlooks, SPC MCDs, or HWO below —
  // those are separate feeds with their own severity values (see next section).
  // State is a fallback used ONLY if Location.Zones/Counties are both empty —
  // and ONLY for this feed. SPC/MCD/HWO always require explicit Zones/Counties.
  // AdditionalEventTypes is the exception to "Filter*" naming — it's additive,
  // not restrictive (see its own comment below).
  "Nws": {
    "State":              "MO",
    "FilterSeverity":     "Severe,Extreme",
    "FilterUrgency":      "",
    "FilterCertainty":    "",
    "FilterEventTypes":   "",
    "AdditionalEventTypes": ""
  },

  // ============================================================================
  // SPC / TEXT-PRODUCT FEEDS — NOT gated by Nws.FilterSeverity above
  // ============================================================================
  // Each of these is a separate NWS/SPC/WPC data source with its own Enabled flag
  // and its own severity value assigned in code (not user-configurable here):
  //   Spc     (Convective Outlook) -> Severity computed from risk category
  //   SpcMcd  (Mesoscale Discussion) -> hardcoded "Severe"
  //   Hwo     (Hazardous Weather Outlook) -> hardcoded "Unknown" (no image, text only)
  //   Ero     (WPC Excessive Rainfall Outlook) -> Severity computed from risk category
  // The ONLY severity gate that applies to these four is each platform's own
  // MinSeverity below — there is no server-side/master filter above them.
  "Spc": {
    "Enabled":              false,
    "CheckIntervalSeconds": 1800
  },

  "SpcMcd": {
    "Enabled":              false,
    "CheckIntervalSeconds": 300
  },

  "Hwo": {
    "Enabled":              false,
    "CheckIntervalSeconds": 300
  },

  // Ero (WPC Excessive Rainfall Outlook) -> Severity computed from Marginal/Slight/Moderate/High
  // risk category. Despite sitting next to the Spc/SpcMcd blocks, ERO is a WPC product, not SPC.
  "Ero": {
    "Enabled":              false,
    "CheckIntervalSeconds": 1800
  },

  // ============================================================================
  // DELIVERY PLATFORMS — where alerts from all feeds above get posted
  // ============================================================================
  // Every block below accepts the same three filter fields:
  //   MinSeverity  - optional extra restriction for THIS platform only. Blank ("")
  //                  means "accept everything that already passed the feed above."
  //   EventTypes   - optional event-name allowlist for THIS platform only.
  //   IncludeSpcOutlooks / IncludeSpcMcd / IncludeHwo / IncludeEro - per-platform
  //                  on/off switch for each non-NWS feed (requires that feed's own
  //                  Enabled: true above). IncludeHwo defaults false since HWO is
  //                  long-form text best suited to a personal channel, not broad
  //                  social platforms.
  "Bluesky": {
    "Enabled": false,
    "Handle": "yourhandle.bsky.social",
    "AppPassword": "YOUR_APP_PASSWORD",
    "MinSeverity": "",
    "EventTypes": "",
    "IncludeSpcOutlooks": true,
    "IncludeSpcMcd": true,
    "IncludeHwo": false,
    "IncludeEro": true
  },

  "Discord": {
