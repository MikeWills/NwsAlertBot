  // ============================================================================
  // SELF-UPDATE — for standalone release binaries (scripts/update.ps1), not this
  // repo owner's own server (deploy.yml deploys straight from master on every push).
  // ============================================================================
  "Update": {
    "AutoApply": false,
    "CheckIntervalHours": 24,
    "GitHubRepo": "MikeWills/NwsAlertBot"
  }
}
